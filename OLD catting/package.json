{
  "name": "slab-cut-planner",
  "private": true,
  "version": "0.2.0",
  "type": "module",
  "main": "electron/main.cjs",
  "scripts": {
    "dev": "vite",
    "build": "tsc -b && vite build",
    "preview": "vite preview",
    "dev:web": "vite",
    "dev:electron": "wait-on tcp:5173 && electron .",
    "dev:desktop": "concurrently -k \"npm:dev:web\" \"npm:dev:electron\"",
    "build:web": "tsc -b && vite build",
    "build:portable": "npm run build:web && electron-builder --win portable",
    "build:portable:dir": "npm run build:web && electron-builder --win portable --dir",
    "test:approval-import": "tsc src/utils/approvalImport.ts --outDir .tmp-approval-test --target ES2022 --module ES2022 --moduleResolution bundler --skipLibCheck --allowSyntheticDefaultImports && node scripts/test-approval-import.mjs"
  },
  "dependencies": {
    "jspdf": "^2.5.1",
    "jszip": "^3.10.1",
    "pdfjs-dist": "^6.0.227",
    "react": "^18.3.1",
    "react-dom": "^18.3.1",
    "xlsx": "^0.18.5",
    "zustand": "^4.5.4"
  },
  "devDependencies": {
    "@types/react": "^18.3.3",
    "@types/react-dom": "^18.3.0",
    "@vitejs/plugin-react": "^4.3.1",
    "concurrently": "^9.0.1",
    "electron": "^32.0.1",
    "electron-builder": "^25.1.8",
    "typescript": "^5.5.4",
    "vite": "^5.4.2",
    "wait-on": "^8.0.1"
  },
  "build": {
    "appId": "com.slabcutplanner.desktop",
    "productName": "SlabCutPlanner",
    "asar": true,
    "directories": {
      "output": "release"
    },
    "files": [
      "dist/**/*",
      "electron/**/*",
      "package.json"
    ],
    "extraMetadata": {
      "main": "electron/main.cjs"
    },
    "win": {
      "target": [
        {
          "target": "portable",
          "arch": [
            "x64"
          ]
        }
      ]
    },
    "portable": {
      "artifactName": "SlabCutPlanner_portable.exe"
    }
  }
}
